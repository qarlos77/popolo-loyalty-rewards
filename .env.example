# ══════════════════════════════════════════════════════
#  Loyalty Rewards — Configuración de instancia
#  Copia este archivo a .env y rellena los valores
# ══════════════════════════════════════════════════════

# ─── Marca ─────────────────────────────────────────────
APP_NAME="MiPizza Rewards"
# URL pública del logo (déjalo vacío para usar el nombre de texto)
APP_LOGO_URL=

# ─── Dominio del app rewards ───────────────────────────
# Dominio donde se servirá rewards (sin https://)
REWARDS_DOMAIN=rewards.mipizza.com

# ─── Odoo ──────────────────────────────────────────────
# URL base de Odoo, sin barra final
ODOO_BASE_URL=https://odoo.mipizza.com
NEXT_PUBLIC_ODOO_HOST=odoo.mipizza.com

# Base de datos de Odoo
ODOO_DB=MiPizzaLoyalty

# Credenciales de PostgreSQL (para setup.sh)
DB_HOST=localhost
DB_USER=odoo
DB_PASS=odoo2024secure

# ─── WooCommerce ───────────────────────────────────────
# URL pública de tu tienda WooCommerce, sin barra final
WC_URL=https://www.mipizza.com
# Consumer Key y Secret de WooCommerce → Ajustes → API avanzada
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Clave de sincronización (compartida Odoo ↔ WordPress) ─
# Genera una clave fuerte: openssl rand -hex 20
SYNC_API_KEY=cambia_esto_por_una_clave_segura

# ─── Panel admin del frontend (/admin) ─────────────────
ADMIN_PASSWORD=cambia_esto

# ─── WhatsApp Business (opcional) ──────────────────────
WA_PHONE_ID=
WA_TOKEN=
# Nombre de los templates en Meta Business
WA_TEMPLATE_EARNED=loyalty_earned
WA_TEMPLATE_REDEEMED=loyalty_redeemed

# ─── Puntos de lealtad ─────────────────────────────────
# Ratio puntos por sol: 0.1 = 1 punto cada S/10
POINTS_RATIO=0.1
# Puntos de bienvenida al registrarse
WELCOME_POINTS=10
# Puntos extra en cumpleaños
BIRTHDAY_POINTS=50
# Días de ventana para beneficio de cumpleaños
BIRTHDAY_WINDOW_DAYS=30
