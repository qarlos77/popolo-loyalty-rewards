<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_loyalty_api" model="ir.ui.view">
        <field name="name">res.config.settings.loyalty.api</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Loyalty Rewards API" name="loyalty_rewards_api"
                     groups="base.group_system">

                    <block title="Rewards Web App">
                        <setting string="App URL" help="URL pública de la app de recompensas">
                            <field name="loyalty_app_url" placeholder="https://rewards.popolopizza.com"/>
                        </setting>
                    </block>

                    <block title="WooCommerce / Integración externa">
                        <setting string="Sync API Key"
                                 help="Clave compartida con WooCommerce. Cópiala en el plugin de WordPress.">
                            <div class="d-flex align-items-center gap-2 w-100">
                                <field name="loyalty_sync_api_key"
                                       widget="CopyClipboardChar"
                                       placeholder="Haz clic en Generar →"
                                       class="flex-grow-1 font-monospace"/>
                                <button type="object"
                                        name="action_generate_sync_api_key"
                                        string="Generar"
                                        class="btn btn-secondary btn-sm"
                                        title="Genera una clave de 16 caracteres y la guarda automáticamente"/>
                            </div>
                        </setting>
                        <setting string="Puntos por unidad de moneda"
                                 help="Ejemplo: 0.10 → 1 punto por cada S/.10 de compra.">
                            <field name="loyalty_points_ratio"/>
                        </setting>
                        <setting string="Puntos por registro"
                                 help="Puntos otorgados al cliente al registrarse por primera vez en el programa de lealtad.">
                            <field name="loyalty_welcome_points"/>
                        </setting>
                    </block>

                    <block title="Beneficio de Cumpleaños">
                        <setting string="Producto de regalo"
                                 help="Producto que se entrega físicamente al cliente en su cumpleaños. Solo canjeable en el local.">
                            <field name="loyalty_birthday_product_id"
                                   options="{'no_create': True, 'no_open': True}"
                                   placeholder="Selecciona un producto…"/>
                        </setting>
                        <setting string="Días de vigencia"
                                 help="Número de días después del cumpleaños en que el beneficio sigue disponible.">
                            <field name="loyalty_birthday_window_days"/>
                        </setting>
                    </block>

                    <block title="WhatsApp (Meta Cloud API)">
                        <setting string="Phone Number ID">
                            <field name="loyalty_wa_phone_id" placeholder="1234567890"/>
                        </setting>
                        <setting string="Permanent Token">
                            <field name="loyalty_wa_token" password="True"/>
                        </setting>
                        <setting string="Template: Puntos ganados">
                            <field name="loyalty_wa_template_earned"/>
                        </setting>
                        <setting string="Template: Premio canjeado">
                            <field name="loyalty_wa_template_redeemed"/>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>
</odoo>
